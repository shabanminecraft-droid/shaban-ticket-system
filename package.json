<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Shaban.Dev Tickets</title><link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet"><style>
*{box-sizing:border-box;margin:0;padding:0}:root{--bg:#0a0c0f;--surface:#111418;--border:rgba(255,255,255,.12);--accent:#00e5ff;--accent2:#7c4dff;--text:#e8eaf0;--muted:#6b7280;--success:#00c896;--error:#ff5252;--warn:#ffb74d}body{background:var(--bg);color:var(--text);font-family:Inter,sans-serif;min-height:100vh}.grid{position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.035) 1px,transparent 1px);background-size:60px 60px;pointer-events:none}nav{height:58px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;background:rgba(10,12,15,.9);border-bottom:.5px solid var(--border);position:sticky;top:0;z-index:3}.logo{font-family:'Share Tech Mono';color:var(--accent);letter-spacing:.14em}.nav-actions{display:flex;gap:10px;align-items:center}.small{font-family:'Share Tech Mono';font-size:11px;color:var(--muted)}button,a.btn{border:0;background:var(--accent);color:#000;padding:11px 18px;font-family:Rajdhani;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;text-decoration:none;clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%)}button:hover,a.btn:hover{opacity:.85}.ghost{background:transparent!important;color:var(--text)!important;border:.5px solid var(--border)!important}.wrap{position:relative;max-width:1100px;margin:0 auto;padding:60px 24px}.hero{text-align:center;padding:55px 0}.badge{display:inline-block;font-family:'Share Tech Mono';font-size:11px;color:var(--accent);border:.5px solid rgba(0,229,255,.3);background:rgba(0,229,255,.05);padding:7px 14px;margin-bottom:20px;letter-spacing:.14em}.hero h1{font-family:Rajdhani;font-size:clamp(52px,9vw,92px);line-height:.9}.hero h1 span{color:var(--accent)}.hero p{color:var(--muted);max-width:600px;margin:20px auto;line-height:1.7}.panel{background:var(--surface);border:.5px solid var(--border);padding:24px;position:relative}.panel:before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent2),var(--accent))}.two{display:grid;grid-template-columns:1fr 1fr;gap:18px}@media(max-width:780px){.two{grid-template-columns:1fr}}label{font-family:'Share Tech Mono';font-size:10px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;display:block;margin-bottom:6px}input,select,textarea{width:100%;background:rgba(255,255,255,.03);border:.5px solid var(--border);color:var(--text);padding:11px 12px;outline:none;margin-bottom:14px}textarea{min-height:115px;resize:vertical}.section-title{font-family:Rajdhani;font-size:32px;margin:20px 0 10px}.muted{color:var(--muted);font-size:14px;line-height:1.7;margin-bottom:20px}.hidden{display:none!important}.err{display:none;color:var(--error);font-family:'Share Tech Mono';font-size:11px;margin:8px 0}.ticket{background:rgba(255,255,255,.025);border:.5px solid rgba(255,255,255,.08);padding:14px;margin-bottom:10px;cursor:pointer}.ticket:hover{border-color:rgba(0,229,255,.3)}.topline{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap}.id{font-family:'Share Tech Mono';color:var(--accent);font-size:11px}.pill{display:inline-block;font-family:'Share Tech Mono';font-size:10px;padding:3px 8px;border:.5px solid var(--border);color:var(--muted);margin-left:6px}.open{color:var(--accent)}.prog{color:var(--accent2)}.closed{color:var(--muted)}.chat{border-top:.5px solid var(--border);margin-top:16px;padding-top:16px}.msg{padding:10px;margin:8px 0;border:.5px solid var(--border);background:rgba(255,255,255,.03)}.msg.admin{border-left:2px solid var(--accent)}.msg.user{border-left:2px solid var(--success)}.msg small{display:block;color:var(--muted);font-family:'Share Tech Mono';font-size:10px;margin-bottom:4px}.row{display:flex;gap:8px}.row input{margin:0}.loginbox{max-width:420px;margin:70px auto}.codeBig{font-family:'Share Tech Mono';color:var(--accent);font-size:12px;margin-top:8px}
</style></head><body><div class="grid"></div><nav><div class="logo">SHABAN.DEV</div><div class="nav-actions"><span id="emailTop" class="small"></span><button class="ghost hidden" id="logoutBtn" onclick="logout()">Logout</button><a class="btn ghost" href="/admin.html">Admin</a></div></nav>
<div class="wrap">
  <div id="auth" class="panel loginbox">
    <div class="badge">// LOGIN CODE</div><h2 class="section-title">Login to Tickets</h2><p class="muted">Enter a valid email. A 6-digit code will be sent to your email and you stay logged in when you come back.</p>
    <div id="stepEmail"><label>Email</label><input id="email" type="email" placeholder="you@example.com"><button onclick="requestCode()">Send Code</button></div>
    <div id="stepCode" class="hidden"><label>Code</label><input id="code" inputmode="numeric" maxlength="6" placeholder="123456"><button onclick="verifyCode()">Verify & Login</button><button class="ghost" onclick="backEmail()">Change Email</button><p id="sentText" class="codeBig"></p></div>
    <p class="err" id="authErr"></p>
  </div>
  <div id="app" class="hidden">
    <section class="hero"><div class="badge">Available for Projects</div><h1>SHABAN<span>.</span></h1><p>Open a support ticket, track your tickets, and chat after Shaban claims it.</p><button onclick="document.getElementById('ticketForm').scrollIntoView({behavior:'smooth'})">Open Ticket</button></section>
    <div class="two">
      <div class="panel" id="ticketForm"><h2 class="section-title">Open a Ticket</h2><p class="muted">Fill this out and it will go into the admin dashboard.</p><label>Name</label><input id="name" placeholder="Your name"><label>Discord</label><input id="discord" placeholder="username or username#0001"><label>Category</label><select id="category"><option>Commission</option><option>Bug Report</option><option>General Question</option><option>Custom Request</option></select><label>Priority</label><select id="priority"><option>Low</option><option>Medium</option><option>High</option></select><label>Subject</label><input id="subject" placeholder="Short summary"><label>Description</label><textarea id="description" placeholder="Explain what you need"></textarea><button onclick="createTicket()">Submit Ticket</button><p class="err" id="ticketErr"></p></div>
      <div class="panel"><h2 class="section-title">My Tickets</h2><p class="muted">Only tickets opened with your email show here.</p><div id="tickets"></div></div>
    </div>
  </div>
</div>
<script>
const API='';let token=localStorage.getItem('shaban_user_token')||'';let currentEmail=localStorage.getItem('shaban_user_email')||'';let pendingEmail='';
function qs(id){return document.getElementById(id)}function authHeaders(){return {'Content-Type':'application/json','Authorization':'Bearer '+token}}
function validEmail(e){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)}
function showErr(id,msg){qs(id).textContent=msg;qs(id).style.display=msg?'block':'none'}
async function requestCode(){const email=qs('email').value.trim().toLowerCase();if(!validEmail(email))return showErr('authErr','Use a valid email.');pendingEmail=email;const r=await fetch(API+'/api/auth/request-code',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email})});const data=await r.json();if(!r.ok)return showErr('authErr',data.error||'Could not send code');showErr('authErr','');qs('stepEmail').classList.add('hidden');qs('stepCode').classList.remove('hidden');qs('sentText').textContent=data.message||'Code sent.'}
function backEmail(){qs('stepCode').classList.add('hidden');qs('stepEmail').classList.remove('hidden')}
async function verifyCode(){const code=qs('code').value.trim();const r=await fetch(API+'/api/auth/verify-code',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:pendingEmail,code})});const data=await r.json();if(!r.ok)return showErr('authErr',data.error||'Wrong code');token=data.token;currentEmail=data.email;localStorage.setItem('shaban_user_token',token);localStorage.setItem('shaban_user_email',currentEmail);boot()}
function logout(){localStorage.removeItem('shaban_user_token');localStorage.removeItem('shaban_user_email');location.reload()}
function boot(){if(token){qs('auth').classList.add('hidden');qs('app').classList.remove('hidden');qs('logoutBtn').classList.remove('hidden');qs('emailTop').textContent=currentEmail;loadTickets()}else{qs('auth').classList.remove('hidden');qs('app').classList.add('hidden')}}
async function createTicket(){const body={name:qs('name').value,discord:qs('discord').value,category:qs('category').value,priority:qs('priority').value,subject:qs('subject').value,description:qs('description').value};const r=await fetch(API+'/api/tickets',{method:'POST',headers:authHeaders(),body:JSON.stringify(body)});const data=await r.json();if(!r.ok)return showErr('ticketErr',data.error||'Could not create ticket');['name','discord','subject','description'].forEach(id=>qs(id).value='');showErr('ticketErr','');loadTickets()}
async function loadTickets(){const r=await fetch(API+'/api/me/tickets',{headers:authHeaders()});if(r.status===401)return logout();const tickets=await r.json();qs('tickets').innerHTML=tickets.length?tickets.map(t=>`<div class="ticket" onclick="openTicket('${t.id}')"><div class="topline"><b>${esc(t.subject)}</b><span class="id">${t.id}</span></div><p class="muted" style="margin:8px 0">${esc(t.category)} · ${esc(t.priority)}</p><span class="pill ${t.status==='Open'?'open':t.status==='In Progress'?'prog':'closed'}">${esc(t.status)}</span>${t.claimed?'<span class="pill">CLAIMED</span>':'<span class="pill">WAITING</span>'}<div id="detail-${t.id}" class="hidden"></div></div>`).join(''):'<p class="muted">No tickets yet.</p>'}
async function openTicket(id){const r=await fetch(API+'/api/me/tickets',{headers:authHeaders()});const tickets=await r.json();const t=tickets.find(x=>x.id===id);const d=qs('detail-'+id);if(!t||!d)return;d.classList.toggle('hidden');d.innerHTML=`<div class="chat"><p class="muted">${esc(t.description)}</p>${t.messages.map(m=>`<div class="msg ${m.from}"><small>${m.from.toUpperCase()} · ${new Date(m.date).toLocaleString()}</small>${esc(m.text)}</div>`).join('')}${t.claimed?`<div class="row"><input id="msg-${t.id}" placeholder="Type message..."><button onclick="sendMsg('${t.id}')">Send</button></div>`:'<p class="muted">Chat opens when admin claims your ticket.</p>'}</div>`}
async function sendMsg(id){const input=qs('msg-'+id);const text=input.value.trim();if(!text)return;await fetch(API+'/api/tickets/'+id+'/messages',{method:'POST',headers:authHeaders(),body:JSON.stringify({text})});loadTickets()}
function esc(s){return String(s||'').replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]))}boot();setInterval(()=>{if(token)loadTickets()},5000);
</script></body></html>
